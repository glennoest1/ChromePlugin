{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash .github/hooks/scripts/docs-session-start.sh",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "matcher": "bash|view|create|edit|str_replace_editor|apply_patch|grep|rg|glob",
        "bash": "bash .github/hooks/scripts/docs-first.sh",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "matcher": "create|edit|str_replace_editor|apply_patch",
        "bash": "bash .github/hooks/scripts/docs-update-required.sh",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "bash .github/hooks/scripts/docs-stop-check.sh",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
